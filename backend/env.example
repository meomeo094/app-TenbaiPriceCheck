# Sao chép thành .env (backend). Không commit .env có secret.

PORT=3001

# Supabase — ghi bảng my_inventory (cần SUPABASE_SERVICE_ROLE_KEY; không dùng anon để upsert)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# TCG AI — Gemini (uu tien v1; v1beta khi model chi co tren beta; cuoi cung fallback model co trong catalog)
# GEMINI_API_KEY=
# Ten model (tuy chon). Mac dinh: gemini-1.5-flash. Key moi co the chi con 2.x — khi do dat: GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL=gemini-1.5-flash
# Khi day 1.5* deu404, service tu goi model cuoi (mac dinh gemini-2.0-flash tren v1)
# GEMINI_MODEL_FALLBACK_FINAL=gemini-2.0-flash
