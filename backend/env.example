# Sao chép thành .env (backend). Không commit .env có secret.

PORT=3001

# Supabase — ghi bảng my_inventory (cần SUPABASE_SERVICE_ROLE_KEY; không dùng anon để upsert)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# TCG AI — Gemini (mac dinh gemini-2.5-flash; user moi khong con 2.0-flash. Khong set apiVersion trong code)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
