# Sao chép thành .env (backend). Không commit .env có secret.

PORT=3001

# Supabase — ghi bảng my_inventory (cần SUPABASE_SERVICE_ROLE_KEY; không dùng anon để upsert)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# TCG AI — Gemini (SDK mac dinh dinh tuyen API; model mac dinh gemini-1.5-flash)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
