# Sao chép thành .env (backend). Không commit .env có secret.

PORT=3001

# Supabase — ghi bảng my_inventory (cần SUPABASE_SERVICE_ROLE_KEY; không dùng anon để upsert)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# TCG AI — Gemini
# GEMINI_API_KEY=
# Ten model (tuy chon). Mac dinh: gemini-1.5-flash-latest. Neu van 404, thu: gemini-2.0-flash
# GEMINI_MODEL=gemini-1.5-flash-latest
