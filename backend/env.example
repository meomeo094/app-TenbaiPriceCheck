# Sao chép thành .env (backend). Không commit .env có secret.

PORT=3001

# Supabase — ghi bảng my_inventory (cần SUPABASE_SERVICE_ROLE_KEY; không dùng anon để upsert)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# TCG AI — Gemini (SDK dung apiVersion v1 trong code; khong ep v1beta)
# GEMINI_API_KEY=
# Ten model (tuy chon). Mac dinh: gemini-1.5-flash. Neu 404, service tu thu gemini-1.5-flash-latest
# GEMINI_MODEL=gemini-1.5-flash
