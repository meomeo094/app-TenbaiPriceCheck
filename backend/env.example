# Sao chép thành .env (backend). Không commit .env có secret.

PORT=3001

# Supabase — ghi bảng my_inventory (cần SUPABASE_SERVICE_ROLE_KEY; không dùng anon để upsert)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# TCG AI — Gemini (chi dung API v1 on dinh; fallback model thu 2: gemini-1.5-flash-latest)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
