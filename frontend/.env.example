# Sao chép thành .env.local khi dev. Trên Vercel: Settings → Environment Variables.
#
# BACKEND_URL — URL Express (proxy Next.js gọi từ server). Ưu tiên trên Vercel.
# NEXT_PUBLIC_API_URL — fallback nếu chưa có BACKEND_URL (dev).
# Không thêm / ở cuối, không thêm /api (ví dụ SAI: https://xxx.ngrok-free.dev/api).
BACKEND_URL=http://127.0.0.1:3001
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
